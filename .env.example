# Airtable — https://airtable.com/create/tokens
AIRTABLE_ACCESS_TOKEN=patXXXXXXXXXXXXXX

# The base ID from the Airtable URL: airtable.com/appXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# The table ID (tblXXX) or table name
AIRTABLE_TABLE_ID=tblXXXXXXXXXXXXXX

# The Airtable view for Blueprint project review (used everywhere except /users)
BLUEPRINT_AIRTABLE_VIEW=Grid view

# The Airtable view containing all hardware projects (used by /users)
HARDWARE_AIRTABLE_VIEW=Hardware view

# Optional: override the default port (default: 3001)
# PORT=3001

# Path to the SQLite database file.
# In production (Docker), set this to a path inside a persistent volume.
# Example: /data/reviews.db  (then mount a volume at /data in Coolify)
# DB_PATH=/data/reviews.db

# Directory where npm run backup saves timestamped copies (default: ./backups/)
# BACKUP_DIR=/data/backups

# Anthropic API key for AI-powered project flagging — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Slack bot token for looking up user profiles on the /users page
# Required scopes: users:read, users:read.email
SLACK_BOT_TOKEN=xoxb-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# PrintLegion — separate Airtable base for 3D printing program
PRINTLEGION_AIRTABLE_ACCESS_TOKEN=patXXXXXXXXXXXXXX
PRINTLEGION_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
PRINTLEGION_AIRTABLE_TABLE_ID=tblXXXXXXXXXXXXXX

# GitHub — optional token for /checker tab (raises rate limit from 60 to 5000 req/hr)
# GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXX
